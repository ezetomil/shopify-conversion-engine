{%- doc -%}
  Small trust-signal row shown under every buy-now button — see
  snippets/dce-buy-now-button.liquid. Kept as its own snippet so the
  wording stays identical everywhere it appears, instead of being
  retyped per section.

  @param {string} [secure_text]
  @param {string} [delivery_text]
  @param {string} [access_text]
  @param {string} [simple_text]

  @example
  {% render 'dce-micro-trust' %}
{%- enddoc -%}

<p class="dce-micro-trust">
  <span>⚡ {{ delivery_text | default: 'Acceso inmediato' }}</span>
  <span>🔒 {{ secure_text | default: 'Pago único' }}</span>
  <span>📄 {{ access_text | default: 'PDF descargable' }}</span>
  <span>📖 {{ simple_text | default: 'Lectura simple' }}</span>
</p>
