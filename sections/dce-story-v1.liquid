{%- comment -%}
  DCE Story — variant 1 (narrative).
  Funnel role: builds emotional authority through a first-person origin
  narrative. This is what makes the offer feel credible before the reader
  sees the price — trust before ask.
{%- endcomment -%}

{{ 'dce-story-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-section-header.css' | asset_url | stylesheet_tag }}

<section
  class="dce-story-v1 dce-section"
  {% if section.settings.background_color != blank %}
    style="background-color: {{ section.settings.background_color }};"
  {% endif %}
>
  <div class="dce-container">
    {%- render 'dce-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      alignment: 'left'
    -%}

    <div class="dce-story-v1__body">
      {%- if section.settings.image != blank -%}
        <div class="dce-story-v1__image">
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag: loading: 'lazy', widths: '400, 600, 800', alt: section.settings.heading
          }}
        </div>
      {%- endif -%}

      <div class="dce-story-v1__text">
        {{ section.settings.body }}

        {%- if section.settings.closing_line != blank -%}
          <p class="dce-story-v1__closing-line">{{ section.settings.closing_line }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DCE — Story v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "¿Quién escribió esto?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Historia"
    },
    {
      "type": "text",
      "id": "closing_line",
      "label": "Línea de cierre destacada",
      "info": "Se muestra con color de acento, al final de la historia."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo"
    }
  ],
  "presets": [
    {
      "name": "DCE — Story v1"
    }
  ]
}
{% endschema %}
