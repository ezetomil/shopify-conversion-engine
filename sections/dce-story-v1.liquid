{%- comment -%}
  DCE Story — variant 1 (narrative + timeline).
  Funnel role: builds emotional authority through a first-person origin
  narrative. This is what makes the offer feel credible before the reader
  sees the price — trust before ask. Timeline blocks are additive to the
  original v1 contract (body/closing_line/image untouched).
{%- endcomment -%}

{{ 'dce-story-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-section-header.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign dce_timeline_steps = section.blocks | where: 'type', 'timeline_step'
-%}

<section
  class="dce-story-v1 dce-section dce-section--dark dce-section--seam"
  {% if section.settings.background_color != blank %}
    style="background-color: {{ section.settings.background_color }};"
  {% endif %}
>
  <div class="dce-story-v1__backdrop" data-dce-animate="glow" aria-hidden="true"></div>
  {%- render 'dce-particles', count: 3 -%}
  <div class="dce-container dce-story-v1__grid{% if section.settings.image == blank %} dce-story-v1__grid--no-image{% endif %}">
    {%- if section.settings.image != blank -%}
      <div class="dce-story-v1__image" data-dce-animate="fade-right">
        {{
          section.settings.image
          | image_url: width: 1000
          | image_tag: loading: 'lazy', widths: '500, 750, 1000', alt: section.settings.heading
        }}
      </div>
    {%- endif -%}

    <div class="dce-story-v1__content">
      {%- render 'dce-section-header',
        eyebrow: section.settings.eyebrow,
        heading: section.settings.heading,
        alignment: 'left'
      -%}

      <div class="dce-story-v1__text" data-dce-animate="blur-in">
        {{ section.settings.body }}

        {%- if section.settings.closing_line != blank -%}
          <p class="dce-story-v1__closing-line">{{ section.settings.closing_line }}</p>
        {%- endif -%}
      </div>

      {%- if dce_timeline_steps.size > 0 -%}
        <ol class="dce-story-v1__timeline">
          {%- for block in dce_timeline_steps -%}
            <li
              class="dce-story-v1__timeline-step"
              data-dce-animate="fade-up"
              style="transition-delay: {{ forloop.index0 | times: 100 }}ms"
              {{ block.shopify_attributes }}
            >
              <span class="dce-story-v1__timeline-dot" aria-hidden="true"></span>
              <p class="dce-story-v1__timeline-label">{{ block.settings.label }}</p>
              <p class="dce-story-v1__timeline-text">{{ block.settings.text }}</p>
            </li>
          {%- endfor -%}
        </ol>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DCE — Story v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "¿Quién escribió esto?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Historia"
    },
    {
      "type": "text",
      "id": "closing_line",
      "label": "Línea de cierre destacada",
      "info": "Se muestra con color de acento, al final de la historia."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo"
    }
  ],
  "blocks": [
    {
      "type": "timeline_step",
      "name": "Paso de la historia",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta",
          "default": "Antes"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Describí este momento en pocas palabras."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — Story v1",
      "blocks": [
        { "type": "timeline_step" },
        { "type": "timeline_step" },
        { "type": "timeline_step" }
      ]
    }
  ]
}
{% endschema %}
