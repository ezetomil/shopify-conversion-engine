{%- comment -%}
  DCE FAQ — variant 1 (native disclosure).
  Funnel role: removes the last objections standing between the reader and
  checkout. Uses native <details>/<summary> instead of a custom JS
  accordion: fully keyboard/screen-reader accessible out of the box, zero
  JavaScript shipped, better for INP than a hand-rolled component.
{%- endcomment -%}

{{ 'dce-faq-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-section-header.css' | asset_url | stylesheet_tag }}
{{ 'dce-icon.css' | asset_url | stylesheet_tag }}
<script src="{{ 'dce-faq-v1.js' | asset_url }}" type="module"></script>

{%- liquid
  assign dce_faqs = section.blocks | where: 'type', 'faq_item'
-%}

<section
  class="dce-faq-v1 dce-section dce-section--dark"
  {% if section.settings.background_color != blank %}
    style="background-color: {{ section.settings.background_color }};"
  {% endif %}
>
  <div class="dce-faq-v1__backdrop" aria-hidden="true"></div>
  <div class="dce-container dce-faq-v1__layout">
    <div class="dce-faq-v1__header-col">
      {%- render 'dce-section-header',
        eyebrow: section.settings.eyebrow,
        heading: section.settings.heading,
        subheading: section.settings.subheading,
        alignment: 'left'
      -%}
    </div>

    {%- if dce_faqs.size > 0 -%}
      <div class="dce-faq-v1__list">
        {%- for block in dce_faqs -%}
          <details
            class="dce-faq-v1__item"
            data-dce-animate="fade-up"
            style="transition-delay: {{ forloop.index0 | times: 60 }}ms"
            {{ block.shopify_attributes }}
          >
            <summary class="dce-faq-v1__question">
              <span>{{ block.settings.question }}</span>
              <span class="dce-faq-v1__caret" aria-hidden="true">{%- render 'dce-icon', name: 'caret' -%}</span>
            </summary>
            <div class="dce-faq-v1__answer">{{ block.settings.answer }}</div>
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DCE — FAQ v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Preguntas frecuentes"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Pregunta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "¿Cuál es tu pregunta?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Respuesta"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — FAQ v1",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item" },
        { "type": "faq_item" }
      ]
    }
  ]
}
{% endschema %}
