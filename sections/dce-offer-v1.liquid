{%- comment -%}
  DCE Offer — variant 1 (price box).
  Funnel role: the conversion moment. Must remove every remaining doubt in
  one glance (what's included, what it costs, that checkout is safe) and
  hand off to Shopify's native purchase flow.

  checkout_style 'instant' uses the same one-click add-to-cart-then-
  checkout button as Hero/CTA final (see snippets/dce-buy-now-button.liquid)
  — every buy action on the page behaves identically by design, see
  docs/00-principles.md, point 4. 'standard' falls back to Dawn's own
  buy-buttons snippet (cart drawer, dynamic checkout, gift-card support)
  for products that need that fuller flow.

  Only valid on product templates: reads the global `product` object.
{%- endcomment -%}

{{ 'dce-offer-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-section-header.css' | asset_url | stylesheet_tag }}
{{ 'dce-icon.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{%- if section.settings.checkout_style == 'instant' -%}
  {{ 'dce-buy-now-button.css' | asset_url | stylesheet_tag }}
  {{ 'dce-micro-trust.css' | asset_url | stylesheet_tag }}
{%- endif -%}
{%- unless product.has_only_default_variant -%}
  {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
  {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
  {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- liquid
  assign dce_includes = section.blocks | where: 'type', 'include_item'
  assign dce_buy_box_block = section.blocks | where: 'type', 'buy_box' | first
  assign product_form_id = 'dce-offer-form-' | append: section.id
-%}

<section class="dce-offer-v1 dce-section" id="dce-offer-{{ section.id }}">
  <div class="dce-offer-v1__backdrop" aria-hidden="true"></div>
  <div class="dce-container dce-offer-v1__container">
    {%- render 'dce-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      subheading: section.settings.subheading
    -%}

    {%- if product != blank -%}
      {%- comment -%}
        No data-dce-animate here on purpose: this box holds the buy button,
        the single highest-stakes element on the page. If the reveal script
        ever failed to run, an opacity:0 buy button would silently kill
        every conversion from that visit — not a risk worth taking for a
        cosmetic entrance effect.
      {%- endcomment -%}
      <product-info
        id="DceOfferProduct-{{ section.id }}"
        class="dce-offer-v1__box"
        data-section="{{ section.id }}"
        data-product-id="{{ product.id }}"
        data-update-url="false"
      >
        {%- if section.settings.badge_text != blank -%}
          <span class="dce-offer-v1__badge">{{ section.settings.badge_text }}</span>
        {%- endif -%}

        {%- if dce_includes.size > 0 -%}
          <ul class="dce-offer-v1__includes" role="list">
            {%- for block in dce_includes -%}
              <li {{ block.shopify_attributes }}>
                <span class="dce-offer-v1__includes-icon">{%- render 'dce-icon', name: 'check_mark' -%}</span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <div class="dce-offer-v1__price" id="price-{{ section.id }}" role="status">
          {%- render 'price', product: product, use_variant: true, show_badges: true, price_class: 'price--large' -%}
        </div>

        <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
        <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

        {%- unless product.has_only_default_variant -%}
          {%- render 'product-variant-picker', product: product, product_form_id: product_form_id, section: section, update_url: false -%}
        {%- endunless -%}

        {%- if section.settings.checkout_style == 'instant' -%}
          <div class="dce-offer-v1__buy-now">
            {%- render 'dce-buy-now-button', product: product, label: section.settings.cta_label, size: 'xl' -%}
          </div>
        {%- else -%}
          {%- comment -%}
            Reuses Dawn's own buy-buttons snippet (cart form, dynamic
            checkout, error handling) instead of reimplementing add-to-cart
            — see docs/00-principles.md on not duplicating logic.
          {%- endcomment -%}
          <div class="dce-offer-v1__buy-buttons">
            {%- render 'buy-buttons',
              block: dce_buy_box_block,
              product: product,
              product_form_id: product_form_id,
              section_id: section.id,
              show_pickup_availability: false
            -%}
          </div>

          {%- if section.settings.reassurance_text != blank -%}
            <p class="dce-offer-v1__reassurance">
              <span class="dce-offer-v1__reassurance-icon">{%- render 'dce-icon', name: 'lock' -%}</span>
              {{ section.settings.reassurance_text }}
            </p>
          {%- endif -%}
        {%- endif -%}
      </product-info>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DCE — Oferta v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Llevate el acceso hoy"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge",
      "info": "Ej: \"Precio de lanzamiento\"."
    },
    {
      "type": "select",
      "id": "checkout_style",
      "label": "Comportamiento del botón de compra",
      "options": [
        { "value": "instant", "label": "Compra directa (agrega y va al checkout)" },
        { "value": "standard", "label": "Carrito estándar de Shopify" }
      ],
      "default": "instant",
      "info": "\"Compra directa\" usa el mismo botón que el resto de la página — ver docs/00-principles.md."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón",
      "default": "Comprar ahora",
      "info": "Solo se usa con \"Compra directa\"."
    },
    {
      "type": "text",
      "id": "reassurance_text",
      "label": "Texto de confianza",
      "default": "Pago 100% seguro · Acceso inmediato al comprar",
      "info": "Solo se usa con \"Carrito estándar\" — \"Compra directa\" ya muestra la fila de micro-confianza estándar."
    }
  ],
  "blocks": [
    {
      "type": "include_item",
      "name": "Qué incluye",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Un ítem de lo que incluye la oferta."
        }
      ]
    },
    {
      "type": "buy_box",
      "name": "Botón de compra",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "label": "Mostrar botones de pago dinámico",
          "info": "Shop Pay / PayPal, etc. Precargan el bundle completo del checkout de Shopify en cuanto la página carga (200+ requests) — activalo solo si medís que compensa la mejora de conversión, porque tiene un costo real de performance.",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — Oferta v1",
      "blocks": [
        { "type": "include_item" },
        { "type": "include_item" },
        { "type": "buy_box" }
      ]
    }
  ]
}
{% endschema %}
