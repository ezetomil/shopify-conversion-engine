{%- comment -%}
  DCE Gallery — variant 1 (real content preview carousel).
  Funnel role: proof of substance right after the reader understands the
  plan — concrete pages of the actual product, not stock imagery. Renders
  nothing unless real gallery_item blocks with actual images exist (see
  docs/00-principles.md — no fabricated/stock content ever).
{%- endcomment -%}

{{ 'dce-gallery-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-section-header.css' | asset_url | stylesheet_tag }}
{{ 'dce-icon.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign dce_gallery_items = section.blocks | where: 'type', 'gallery_item'
-%}

{%- if dce_gallery_items.size > 0 -%}
  <section class="dce-gallery-v1 dce-section">
    <div class="dce-container">
      {%- render 'dce-section-header',
        eyebrow: section.settings.eyebrow,
        heading: section.settings.heading,
        subheading: section.settings.subheading
      -%}
    </div>

    <div class="dce-gallery-v1__viewport" data-dce-animate="fade-up" style="transition-delay: 120ms">
      <ul class="dce-gallery-v1__track" role="list" data-dce-gallery-track>
        {%- for block in dce_gallery_items -%}
          <li class="dce-gallery-v1__item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag: loading: 'lazy', widths: '450, 675, 900', alt: block.settings.alt | default: section.settings.heading
              }}
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>

      {%- if dce_gallery_items.size > 1 -%}
        <button type="button" class="dce-gallery-v1__nav dce-gallery-v1__nav--prev" data-dce-gallery-prev aria-label="Página anterior">
          {%- render 'dce-icon', name: 'arrow' -%}
        </button>
        <button type="button" class="dce-gallery-v1__nav dce-gallery-v1__nav--next" data-dce-gallery-next aria-label="Página siguiente">
          {%- render 'dce-icon', name: 'arrow' -%}
        </button>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "DCE — Galería v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Mirá parte de la guía"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Esto es exactamente lo que vas a recibir después de comprar."
    }
  ],
  "blocks": [
    {
      "type": "gallery_item",
      "name": "Página real",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen",
          "info": "Usá únicamente páginas reales del ebook — nunca imágenes de stock."
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Texto alternativo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — Galería v1",
      "blocks": []
    }
  ]
}
{% endschema %}
