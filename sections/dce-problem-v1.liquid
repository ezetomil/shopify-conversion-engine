{%- comment -%}
  DCE Problem — variant 1 (statement stack).

  Funnel role: builds identification with the reader's current friction
  before the offer is introduced. Fixes the content contract for the
  Problem family (v2, v3...) — see docs/00-principles.md and
  docs/05-components-catalog.md.

  Deliberately not a card grid: a list format reads as information, not
  as something felt. Large sequential statements, one idea at a time,
  read closer to how the reader actually experiences the thought.
{%- endcomment -%}

{{ 'dce-problem-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-section-header.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign dce_pain_points = section.blocks | where: 'type', 'pain_point_item'
-%}

<section
  class="dce-problem-v1 dce-section dce-section--dark"
  {% if section.settings.background_color != blank %}
    style="background-color: {{ section.settings.background_color }};"
  {% endif %}
>
  <div class="dce-problem-v1__backdrop" data-dce-animate="glow" aria-hidden="true"></div>
  {%- render 'dce-particles', count: 3 -%}
  <div class="dce-container dce-problem-v1__container">
    {%- render 'dce-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      subheading: section.settings.subheading
    -%}

    {%- if dce_pain_points.size > 0 -%}
      <ul class="dce-problem-v1__stack" role="list">
        {%- for block in dce_pain_points -%}
          <li
            class="dce-problem-v1__line"
            data-dce-animate="fade-up"
            style="transition-delay: {{ forloop.index0 | times: 120 }}ms"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.text }}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DCE — Problema v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "¿Te sentís identificado?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Esto es lo que probablemente te está pasando"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "info": "Opcional. Sobrescribe el fondo oscuro por defecto."
    }
  ],
  "blocks": [
    {
      "type": "pain_point_item",
      "name": "Frase",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ícono",
          "info": "No se usa en esta variante — se mantiene por compatibilidad con futuras variantes del componente.",
          "options": [
            { "value": "none", "label": "Sin ícono" },
            { "value": "check_mark", "label": "Check" },
            { "value": "question_mark", "label": "Signo de pregunta" },
            { "value": "stopwatch", "label": "Cronómetro (tiempo)" },
            { "value": "lock", "label": "Candado (bloqueo)" },
            { "value": "heart", "label": "Corazón" },
            { "value": "star", "label": "Estrella" },
            { "value": "lightning_bolt", "label": "Rayo (urgencia)" },
            { "value": "price_tag", "label": "Etiqueta de precio" },
            { "value": "chat_bubble", "label": "Globo de chat" },
            { "value": "eye", "label": "Ojo" },
            { "value": "return", "label": "Flecha de retorno" },
            { "value": "map_pin", "label": "Pin de mapa" },
            { "value": "plane", "label": "Avión" },
            { "value": "fire", "label": "Fuego" },
            { "value": "clipboard", "label": "Portapapeles" },
            { "value": "plant", "label": "Planta (crecimiento)" }
          ],
          "default": "none"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto",
          "default": "Una frase corta, humana y concreta."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — Problema v1",
      "blocks": [
        { "type": "pain_point_item" },
        { "type": "pain_point_item" },
        { "type": "pain_point_item" }
      ]
    }
  ]
}
{% endschema %}
