{%- comment -%}
  DCE Stats — variant 1 (impact numbers strip).
  Funnel role: fast, scannable proof of substance right after the Hero —
  before the reader has committed to reading anything, big numbers signal
  "this is real and substantial" in under a second.
{%- endcomment -%}

{{ 'dce-stats-v1.css' | asset_url | stylesheet_tag }}
<script src="{{ 'dce-stats-v1.js' | asset_url }}" type="module"></script>

{%- liquid
  assign dce_stats = section.blocks | where: 'type', 'stat_item'
-%}

{%- if dce_stats.size > 0 -%}
  <section class="dce-stats-v1 dce-section dce-section--dark dce-stats-v1--compact">
    <div class="dce-stats-v1__backdrop" aria-hidden="true"></div>
    <div class="dce-container">
      <div class="dce-stats-v1__grid">
        {%- for block in dce_stats -%}
          <div
            class="dce-stats-v1__item{% if block.settings.featured %} dce-stats-v1__item--featured{% endif %}"
            data-dce-animate="scale-in"
            style="transition-delay: {{ forloop.index0 | times: 80 }}ms"
            {{ block.shopify_attributes }}
          >
            <dce-stat class="dce-stats-v1__value" data-value="{{ block.settings.value }}">{{ block.settings.value }}</dce-stat>
            <p class="dce-stats-v1__label">{{ block.settings.label }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "DCE — Stats v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [],
  "blocks": [
    {
      "type": "stat_item",
      "name": "Número",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Valor",
          "info": "Puede incluir un sufijo, ej: \"35+\" o \"30\".",
          "default": "35+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Descripción",
          "default": "Descripción del número"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Destacar (más grande)",
          "info": "Usalo en el número más impactante — no marques más de uno.",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — Stats v1",
      "blocks": [
        { "type": "stat_item" },
        { "type": "stat_item" },
        { "type": "stat_item" }
      ]
    }
  ]
}
{% endschema %}
