{%- comment -%}
  DCE Hero — variant 1 (fullscreen 60/40, cinematic).

  First implementation of the Hero component family. Fixes the content
  contract (settings/block ids) that every future Hero variant (v2, v3...)
  must also implement — see docs/00-principles.md, point 2, and
  docs/05-components-catalog.md. Every field added since the original v1
  is additive (new optional settings/blocks) — nothing already shipped
  was renamed or removed.

  This section owns no design decisions in its content: every visible
  string, image and link comes from section settings/blocks, so a product's
  templates/product.{handle}.json is the only file that changes to produce
  a different Hero — never this file. See docs/06-content-engine.md.
{%- endcomment -%}

{{ 'dce-hero-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-button.css' | asset_url | stylesheet_tag }}
{{ 'dce-icon.css' | asset_url | stylesheet_tag }}
{{ 'dce-rating-stars.css' | asset_url | stylesheet_tag }}
{%- if section.settings.cta_primary_style == 'buy_now' -%}
  {{ 'dce-buy-now-button.css' | asset_url | stylesheet_tag }}
  {{ 'dce-micro-trust.css' | asset_url | stylesheet_tag }}
{%- endif -%}
<script src="{{ 'dce-hero-v1.js' | asset_url }}" type="module"></script>

{%- liquid
  assign dce_has_actions = false
  if section.settings.cta_primary_label != blank or section.settings.cta_secondary_label != blank
    assign dce_has_actions = true
  endif

  assign dce_trust_badges = section.blocks | where: 'type', 'trust_badge'

  assign dce_heading = section.settings.heading
  if section.settings.heading_accent != blank and section.settings.heading contains section.settings.heading_accent
    assign dce_accent_markup = section.settings.heading_accent | prepend: '<span class="dce-hero-v1__heading-accent">' | append: '</span>'
    assign dce_heading = section.settings.heading | replace: section.settings.heading_accent, dce_accent_markup
  endif
-%}

<section
  class="dce-hero-v1 dce-section{% if section.settings.height == 'viewport' %} dce-hero-v1--viewport{% endif %}"
  {% if section.settings.background_color != blank %}
    style="background-color: {{ section.settings.background_color }};"
  {% endif %}
>
  <div class="dce-hero-v1__backdrop" aria-hidden="true">
    <div class="dce-hero-v1__glow"></div>
    <div class="dce-hero-v1__noise"></div>
    <div class="dce-hero-v1__particles" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
  </div>

  <div class="dce-container dce-hero-v1__grid">
    <div class="dce-hero-v1__inner">
      {%- if section.settings.rating > 0 or section.settings.social_proof_text != blank -%}
        <div class="dce-hero-v1__proof" data-dce-animate="fade-up">
          {%- if section.settings.rating > 0 -%}
            {%- render 'dce-rating-stars', rating: section.settings.rating -%}
          {%- endif -%}
          {%- if section.settings.social_proof_text != blank -%}
            <span class="dce-hero-v1__proof-text">{{ section.settings.social_proof_text }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.badge_text != blank -%}
        <span class="dce-hero-v1__badge" data-dce-animate="fade-up" style="transition-delay: 60ms">{{ section.settings.badge_text }}</span>
      {%- endif -%}

      {%- if section.settings.eyebrow != blank -%}
        <p class="dce-hero-v1__eyebrow" data-dce-animate="fade-up" style="transition-delay: 120ms">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 class="dce-hero-v1__heading" data-dce-animate="blur-in" style="transition-delay: 180ms">{{ dce_heading }}</h1>

      {%- if section.settings.subheading != blank -%}
        <p class="dce-hero-v1__subheading" data-dce-animate="fade-up" style="transition-delay: 260ms">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.cta_primary_style == 'buy_now' -%}
        <div class="dce-hero-v1__actions" data-dce-animate="fade-up" style="transition-delay: 340ms">
          {%- render 'dce-buy-now-button', product: product, label: section.settings.cta_primary_label, size: 'xl' -%}
        </div>
      {%- elsif dce_has_actions -%}
        <div class="dce-hero-v1__actions" data-dce-animate="fade-up" style="transition-delay: 340ms">
          {%- render 'dce-button',
            label: section.settings.cta_primary_label,
            url: section.settings.cta_primary_url,
            variant: 'primary',
            size: 'xl',
            magnetic: true
          -%}
          {%- render 'dce-button',
            label: section.settings.cta_secondary_label,
            url: section.settings.cta_secondary_url,
            variant: 'ghost',
            size: 'xl'
          -%}
        </div>
      {%- endif -%}

      {%- if dce_trust_badges.size > 0 -%}
        <ul class="dce-hero-v1__trust-badges" role="list" data-dce-animate="fade-up" style="transition-delay: 400ms">
          {%- for block in dce_trust_badges -%}
            <li class="dce-hero-v1__trust-badge" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank and block.settings.icon != 'none' -%}
                {%- render 'dce-icon', name: block.settings.icon -%}
              {%- endif -%}
              {%- if block.settings.logo != blank -%}
                {{
                  block.settings.logo
                  | image_url: width: 240
                  | image_tag: loading: 'lazy', widths: '120, 180, 240', alt: block.settings.label
                }}
              {%- endif -%}
              {%- if block.settings.label != blank -%}
                <span>{{ block.settings.label }}</span>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    {%- if section.settings.image != blank -%}
      <dce-tilt class="dce-hero-v1__visual" data-dce-animate="scale-in" style="transition-delay: 260ms">
        <div class="dce-hero-v1__visual-glow" aria-hidden="true"></div>
        <div class="dce-hero-v1__visual-shadow" aria-hidden="true"></div>
        {{
          section.settings.image
          | image_url: width: 1920
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '640, 960, 1280, 1600, 1920',
            sizes: '(min-width: 1024px) 44vw, 82vw',
            alt: section.settings.image.alt | default: section.settings.heading
        }}
      </dce-tilt>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DCE — Hero v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Prueba social"
    },
    {
      "type": "range",
      "id": "rating",
      "label": "Calificación (0 = ocultar)",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 0,
      "info": "Usá solo si tenés una calificación real — no se muestra si queda en 0."
    },
    {
      "type": "text",
      "id": "social_proof_text",
      "label": "Texto de prueba social",
      "info": "Ej: \"128 reseñas verificadas\". Solo afirmaciones reales."
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge",
      "info": "Opcional. Ej: \"Ebook Digital\"."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "info": "Texto corto arriba del título."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Un título que comunique tu promesa en una frase"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Palabra o frase destacada del título",
      "info": "Opcional. Debe ser un fragmento exacto del título — se resalta con un degradé de color."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Una frase que amplíe la promesa del título y sume contexto."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "header",
      "content": "Llamado a la acción principal"
    },
    {
      "type": "select",
      "id": "cta_primary_style",
      "label": "Comportamiento del botón",
      "options": [
        { "value": "link", "label": "Link normal (usa la URL de abajo)" },
        { "value": "buy_now", "label": "Compra directa (agrega al carrito y va al checkout)" }
      ],
      "default": "link",
      "info": "\"Compra directa\" ignora la URL y usa el producto de esta página."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Texto del botón",
      "default": "Empezar ahora"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Link del botón",
      "info": "Solo se usa si el comportamiento es \"Link normal\"."
    },
    {
      "type": "header",
      "content": "Llamado a la acción secundario"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Texto del botón"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Link del botón"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Altura",
      "options": [
        { "value": "auto", "label": "Automática (según el contenido)" },
        { "value": "viewport", "label": "Pantalla completa" }
      ],
      "default": "viewport"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "info": "Opcional. Si se deja vacío, usa el fondo oscuro cinematográfico por defecto."
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Indicador de confianza",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ícono",
          "options": [
            { "value": "none", "label": "Sin ícono" },
            { "value": "check_mark", "label": "Check" },
            { "value": "lock", "label": "Candado" },
            { "value": "lightning_bolt", "label": "Rayo" },
            { "value": "star", "label": "Estrella" },
            { "value": "clipboard", "label": "Portapapeles" },
            { "value": "heart", "label": "Corazón" }
          ],
          "default": "check_mark"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo",
          "info": "Opcional, reemplaza al ícono si se completa."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Texto",
          "info": "Usá solo afirmaciones reales y verificables — nunca cifras inventadas."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — Hero v1",
      "blocks": []
    }
  ]
}
{% endschema %}
