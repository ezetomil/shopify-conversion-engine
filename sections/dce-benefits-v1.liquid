{%- comment -%}
  DCE Benefits — variant 1 (numbered list).
  Funnel role: translates the product into concrete outcomes/results.
  Numbered framing signals structure and progression, which increases
  perceived value and completion likelihood for course/ebook-style products.
{%- endcomment -%}

{{ 'dce-benefits-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-section-header.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign dce_benefits = section.blocks | where: 'type', 'benefit_item'
-%}

<section
  class="dce-benefits-v1 dce-section"
  {% if section.settings.background_color != blank %}
    style="background-color: {{ section.settings.background_color }};"
  {% endif %}
>
  <div class="dce-container">
    {%- render 'dce-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      subheading: section.settings.subheading
    -%}

    {%- if dce_benefits.size > 0 -%}
      <ol class="dce-benefits-v1__list">
        {%- for block in dce_benefits -%}
          <li class="dce-benefits-v1__item" data-dce-animate {{ block.shopify_attributes }}>
            <span class="dce-benefits-v1__number">{{ forloop.index }}</span>
            <div class="dce-benefits-v1__body">
              <p class="dce-benefits-v1__title">{{ block.settings.title }}</p>
              {%- if block.settings.text != blank -%}
                <p class="dce-benefits-v1__text">{{ block.settings.text }}</p>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ol>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DCE — Beneficios v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "¿Qué vas a lograr?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo"
    }
  ],
  "blocks": [
    {
      "type": "benefit_item",
      "name": "Beneficio",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Un resultado concreto"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descripción"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — Beneficios v1",
      "blocks": [
        { "type": "benefit_item" },
        { "type": "benefit_item" },
        { "type": "benefit_item" }
      ]
    }
  ]
}
{% endschema %}
