{%- comment -%}
  DCE Benefits — variant 1 (numbered list).
  Funnel role: translates the product into concrete outcomes/results.
  Numbered framing signals structure and progression, which increases
  perceived value and completion likelihood for course/ebook-style products.
{%- endcomment -%}

{{ 'dce-benefits-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-section-header.css' | asset_url | stylesheet_tag }}
{{ 'dce-icon.css' | asset_url | stylesheet_tag }}
{{ 'dce-buy-now-button.css' | asset_url | stylesheet_tag }}
<script src="{{ 'dce-benefits-v1.js' | asset_url }}" type="module"></script>

{%- liquid
  assign dce_benefits = section.blocks | where: 'type', 'benefit_item'
  assign dce_entrances = 'fade-left,fade-right,scale-in,fade-glow' | split: ','
-%}

<section
  class="dce-benefits-v1 dce-section dce-section--dark"
  {% if section.settings.background_color != blank %}
    style="background-color: {{ section.settings.background_color }};"
  {% endif %}
>
  <div class="dce-benefits-v1__backdrop" data-dce-animate="glow" aria-hidden="true"></div>
  <div class="dce-benefits-v1__fog" aria-hidden="true"></div>
  <div class="dce-container">
    {%- render 'dce-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      subheading: section.settings.subheading
    -%}

    {%- if dce_benefits.size > 0 -%}
      <div class="dce-benefits-v1__scene" data-dce-benefits-path>
        <div class="dce-benefits-v1__current" aria-hidden="true"></div>
        <div class="dce-benefits-v1__nebula" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span><span></span>
        </div>
        <ol class="dce-benefits-v1__list">
        {%- for block in dce_benefits -%}
          {%- liquid
            assign dce_entrance_index = forloop.index0 | modulo: 4
            assign dce_entrance = dce_entrances[dce_entrance_index]
            assign dce_is_last = false
            if forloop.last
              assign dce_is_last = true
            endif
          -%}
          <li
            class="dce-benefits-v1__item dce-benefits-v1__item--pos-{{ forloop.index }}{% if block.settings.featured %} dce-benefits-v1__item--featured{% endif %}"
            data-dce-animate="{{ dce_entrance }}"
            data-dce-press
            data-dce-benefits-step
            style="transition-delay: {{ forloop.index0 | times: 90 }}ms"
            {{ block.shopify_attributes }}
          >
            <div class="dce-benefits-v1__particle-zone dce-benefits-v1__particle-zone--{{ forloop.index }}" aria-hidden="true">
              <span></span><span></span>
            </div>
            <div class="dce-benefits-v1__card">
              <span class="dce-benefits-v1__absorb-flash" aria-hidden="true"></span>
              <div class="dce-benefits-v1__step">
                <span class="dce-benefits-v1__number" aria-hidden="true">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</span>
                <span class="dce-benefits-v1__badge">
                  {%- if block.settings.icon != blank and block.settings.icon != 'none' -%}
                    {%- render 'dce-icon', name: block.settings.icon -%}
                  {%- else -%}
                    {{ forloop.index }}
                  {%- endif -%}
                  <span class="dce-benefits-v1__pulse-ring" aria-hidden="true"></span>
                </span>
              </div>
              <div class="dce-benefits-v1__body">
                <p class="dce-benefits-v1__title">{{ block.settings.title }}</p>
                {%- if block.settings.text != blank -%}
                  <p class="dce-benefits-v1__text">{{ block.settings.text }}</p>
                {%- endif -%}
              </div>
              {%- if dce_is_last -%}
                <span class="dce-benefits-v1__burst" aria-hidden="true">
                  <span></span><span></span><span></span>
                </span>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
        </ol>
      </div>
    {%- endif -%}

    {%- if section.settings.result_option_b != blank -%}
      <div class="dce-benefits-v1__convergence" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
      <div class="dce-benefits-v1__result" data-dce-animate="pop">
        <div class="dce-benefits-v1__result-glow" aria-hidden="true"></div>
        {%- if section.settings.result_eyebrow != blank -%}
          <p class="dce-benefits-v1__result-eyebrow">{{ section.settings.result_eyebrow }}</p>
        {%- endif -%}
        <div class="dce-benefits-v1__result-choice">
          {%- if section.settings.result_option_a != blank -%}
            <p class="dce-benefits-v1__result-option dce-benefits-v1__result-option--muted">{{ section.settings.result_option_a }}</p>
          {%- endif -%}
          <span class="dce-benefits-v1__result-or" aria-hidden="true">o</span>
          <p class="dce-benefits-v1__result-option dce-benefits-v1__result-option--glow">{{ section.settings.result_option_b }}</p>
        </div>
        {%- if section.settings.result_footnote != blank -%}
          <p class="dce-benefits-v1__result-footnote">
            {{ section.settings.result_footnote }}
            {%- if section.settings.result_footnote_emphasis != blank -%}
              <strong>{{ section.settings.result_footnote_emphasis }}</strong>
            {%- endif -%}
          </p>
        {%- endif -%}
        {%- if section.settings.result_cta_label != blank -%}
          <div class="dce-benefits-v1__result-cta">
            {%- render 'dce-buy-now-button', product: product, label: section.settings.result_cta_label, size: 'md', show_micro_trust: false -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DCE — Beneficios v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "¿Qué vas a lograr?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo"
    },
    {
      "type": "header",
      "content": "Caja final (dos caminos)"
    },
    {
      "type": "text",
      "id": "result_eyebrow",
      "label": "Eyebrow",
      "default": "Hoy tenés dos caminos"
    },
    {
      "type": "text",
      "id": "result_option_a",
      "label": "Opción A (atenuada)",
      "default": "Seguir exactamente igual."
    },
    {
      "type": "text",
      "id": "result_option_b",
      "label": "Opción B (iluminada)",
      "default": "Dar el primer paso."
    },
    {
      "type": "textarea",
      "id": "result_footnote",
      "label": "Frase pequeña",
      "default": "No ocurre de un día para otro. Pero todas las historias empiezan exactamente igual."
    },
    {
      "type": "text",
      "id": "result_footnote_emphasis",
      "label": "Cierre destacado",
      "default": "Con una decisión."
    },
    {
      "type": "text",
      "id": "result_cta_label",
      "label": "Texto del botón",
      "default": "Quiero empezar"
    }
  ],
  "blocks": [
    {
      "type": "benefit_item",
      "name": "Beneficio",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ícono",
          "info": "Sin ícono, muestra el número de orden.",
          "options": [
            { "value": "none", "label": "Sin ícono (mostrar número)" },
            { "value": "lightning_bolt", "label": "Rayo" },
            { "value": "check_mark", "label": "Check" },
            { "value": "star", "label": "Estrella" },
            { "value": "heart", "label": "Corazón" },
            { "value": "clipboard", "label": "Portapapeles" },
            { "value": "plant", "label": "Planta (crecimiento)" },
            { "value": "map_pin", "label": "Pin de mapa" },
            { "value": "eye", "label": "Ojo" },
            { "value": "plane", "label": "Avión (libertad)" }
          ],
          "default": "lightning_bolt"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Un resultado concreto"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descripción"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Destacar (tarjeta más grande)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — Beneficios v1",
      "blocks": [
        { "type": "benefit_item" },
        { "type": "benefit_item" },
        { "type": "benefit_item" }
      ]
    }
  ]
}
{% endschema %}
