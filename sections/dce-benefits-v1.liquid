{%- comment -%}
  DCE Benefits — variant 1 (numbered list).
  Funnel role: translates the product into concrete outcomes/results.
  Numbered framing signals structure and progression, which increases
  perceived value and completion likelihood for course/ebook-style products.
{%- endcomment -%}

{{ 'dce-benefits-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-section-header.css' | asset_url | stylesheet_tag }}
{{ 'dce-icon.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign dce_benefits = section.blocks | where: 'type', 'benefit_item'
  assign dce_entrances = 'fade-left,fade-right,scale-in,fade-glow' | split: ','

  assign dce_result_lines = ''
  if section.settings.result_line_1 != blank
    assign dce_result_lines = dce_result_lines | append: section.settings.result_line_1 | append: '||'
  endif
  if section.settings.result_line_2 != blank
    assign dce_result_lines = dce_result_lines | append: section.settings.result_line_2 | append: '||'
  endif
  if section.settings.result_line_3 != blank
    assign dce_result_lines = dce_result_lines | append: section.settings.result_line_3 | append: '||'
  endif
  if section.settings.result_line_4 != blank
    assign dce_result_lines = dce_result_lines | append: section.settings.result_line_4 | append: '||'
  endif
  assign dce_result_lines = dce_result_lines | split: '||'
-%}

<section
  class="dce-benefits-v1 dce-section dce-section--dark"
  {% if section.settings.background_color != blank %}
    style="background-color: {{ section.settings.background_color }};"
  {% endif %}
>
  <div class="dce-benefits-v1__backdrop" data-dce-animate="glow" aria-hidden="true"></div>
  <div class="dce-container">
    {%- render 'dce-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      subheading: section.settings.subheading
    -%}

    {%- if dce_benefits.size > 0 -%}
      <ol class="dce-benefits-v1__list">
        {%- for block in dce_benefits -%}
          {%- liquid
            assign dce_entrance_index = forloop.index0 | modulo: 4
            assign dce_entrance = dce_entrances[dce_entrance_index]
          -%}
          <li
            class="dce-benefits-v1__item{% if block.settings.featured %} dce-benefits-v1__item--featured{% endif %}"
            data-dce-animate="{{ dce_entrance }}"
            data-dce-press
            style="transition-delay: {{ forloop.index0 | times: 90 }}ms"
            {{ block.shopify_attributes }}
          >
            <div class="dce-benefits-v1__step">
              <span class="dce-benefits-v1__number" aria-hidden="true">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</span>
              <span class="dce-benefits-v1__badge">
                {%- if block.settings.icon != blank and block.settings.icon != 'none' -%}
                  {%- render 'dce-icon', name: block.settings.icon -%}
                {%- else -%}
                  {{ forloop.index }}
                {%- endif -%}
              </span>
            </div>
            <div class="dce-benefits-v1__body">
              <p class="dce-benefits-v1__title">{{ block.settings.title }}</p>
              {%- if block.settings.text != blank -%}
                <p class="dce-benefits-v1__text">{{ block.settings.text }}</p>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ol>
    {%- endif -%}

    {%- if dce_result_lines.size > 0 -%}
      <div class="dce-benefits-v1__result" data-dce-animate="pop">
        <div class="dce-benefits-v1__result-glow" aria-hidden="true"></div>
        <div class="dce-benefits-v1__result-lines">
          {%- for line in dce_result_lines -%}
            {%- unless forloop.first -%}
              <span class="dce-benefits-v1__result-arrow" aria-hidden="true">↓</span>
            {%- endunless -%}
            <p class="dce-benefits-v1__result-line">{{ line }}</p>
          {%- endfor -%}
        </div>
        {%- if section.settings.result_footnote != blank -%}
          <p class="dce-benefits-v1__result-footnote">{{ section.settings.result_footnote }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DCE — Beneficios v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "¿Qué vas a lograr?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo"
    },
    {
      "type": "header",
      "content": "Caja de resultado"
    },
    {
      "type": "text",
      "id": "result_line_1",
      "label": "Línea 1",
      "default": "Más claridad."
    },
    {
      "type": "text",
      "id": "result_line_2",
      "label": "Línea 2",
      "default": "Más acción."
    },
    {
      "type": "text",
      "id": "result_line_3",
      "label": "Línea 3",
      "default": "Primer ingreso."
    },
    {
      "type": "text",
      "id": "result_line_4",
      "label": "Línea 4",
      "default": "Más libertad."
    },
    {
      "type": "textarea",
      "id": "result_footnote",
      "label": "Frase pequeña",
      "default": "No ocurre de un día para otro. Pero todo empieza con un primer paso."
    }
  ],
  "blocks": [
    {
      "type": "benefit_item",
      "name": "Beneficio",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ícono",
          "info": "Sin ícono, muestra el número de orden.",
          "options": [
            { "value": "none", "label": "Sin ícono (mostrar número)" },
            { "value": "lightning_bolt", "label": "Rayo" },
            { "value": "check_mark", "label": "Check" },
            { "value": "star", "label": "Estrella" },
            { "value": "heart", "label": "Corazón" },
            { "value": "clipboard", "label": "Portapapeles" },
            { "value": "plant", "label": "Planta (crecimiento)" },
            { "value": "map_pin", "label": "Pin de mapa" },
            { "value": "eye", "label": "Ojo" },
            { "value": "plane", "label": "Avión (libertad)" }
          ],
          "default": "lightning_bolt"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Un resultado concreto"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descripción"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Destacar (tarjeta más grande)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — Beneficios v1",
      "blocks": [
        { "type": "benefit_item" },
        { "type": "benefit_item" },
        { "type": "benefit_item" }
      ]
    }
  ]
}
{% endschema %}
