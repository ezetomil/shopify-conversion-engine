{%- comment -%}
  DCE Benefits — variant 1 (numbered list).
  Funnel role: translates the product into concrete outcomes/results.
  Numbered framing signals structure and progression, which increases
  perceived value and completion likelihood for course/ebook-style products.
{%- endcomment -%}

{{ 'dce-benefits-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-section-header.css' | asset_url | stylesheet_tag }}
{{ 'dce-icon.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign dce_benefits = section.blocks | where: 'type', 'benefit_item'
-%}

<section
  class="dce-benefits-v1 dce-section dce-section--dark"
  {% if section.settings.background_color != blank %}
    style="background-color: {{ section.settings.background_color }};"
  {% endif %}
>
  <div class="dce-benefits-v1__backdrop" aria-hidden="true"></div>
  <div class="dce-container">
    {%- render 'dce-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      subheading: section.settings.subheading
    -%}

    {%- if dce_benefits.size > 0 -%}
      <ol class="dce-benefits-v1__list">
        {%- for block in dce_benefits -%}
          <li
            class="dce-benefits-v1__item{% if block.settings.featured %} dce-benefits-v1__item--featured{% endif %}"
            data-dce-animate="fade-right"
            data-dce-press
            style="transition-delay: {{ forloop.index0 | times: 70 }}ms"
            {{ block.shopify_attributes }}
          >
            <span class="dce-benefits-v1__badge">
              {%- if block.settings.icon != blank and block.settings.icon != 'none' -%}
                {%- render 'dce-icon', name: block.settings.icon -%}
              {%- else -%}
                {{ forloop.index }}
              {%- endif -%}
            </span>
            <div class="dce-benefits-v1__body">
              <p class="dce-benefits-v1__title">{{ block.settings.title }}</p>
              {%- if block.settings.text != blank -%}
                <p class="dce-benefits-v1__text">{{ block.settings.text }}</p>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ol>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DCE — Beneficios v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "¿Qué vas a lograr?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo"
    }
  ],
  "blocks": [
    {
      "type": "benefit_item",
      "name": "Beneficio",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ícono",
          "info": "Sin ícono, muestra el número de orden.",
          "options": [
            { "value": "none", "label": "Sin ícono (mostrar número)" },
            { "value": "lightning_bolt", "label": "Rayo" },
            { "value": "check_mark", "label": "Check" },
            { "value": "star", "label": "Estrella" },
            { "value": "heart", "label": "Corazón" },
            { "value": "clipboard", "label": "Portapapeles" },
            { "value": "plant", "label": "Planta (crecimiento)" },
            { "value": "map_pin", "label": "Pin de mapa" },
            { "value": "eye", "label": "Ojo" }
          ],
          "default": "lightning_bolt"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Un resultado concreto"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descripción"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Destacar (tarjeta más grande)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — Beneficios v1",
      "blocks": [
        { "type": "benefit_item" },
        { "type": "benefit_item" },
        { "type": "benefit_item" }
      ]
    }
  ]
}
{% endschema %}
