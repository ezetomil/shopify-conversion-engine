{%- comment -%}
  DCE Transformation — variant 1 (connected timeline).
  Funnel role: makes the promised outcome concrete by contrasting the
  reader's current state against the state after using the product, as a
  single connected sequence rather than two isolated boxes.
{%- endcomment -%}

{{ 'dce-transformation-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-section-header.css' | asset_url | stylesheet_tag }}
{{ 'dce-icon.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign dce_rows = section.blocks | where: 'type', 'comparison_item'
-%}

<section
  class="dce-transformation-v1 dce-section{% if section.settings.dark_mode %} dce-section--dark{% endif %}"
  {% if section.settings.background_color != blank %}
    style="background-color: {{ section.settings.background_color }};"
  {% endif %}
>
  <div class="dce-transformation-v1__backdrop" aria-hidden="true"></div>
  <div class="dce-container">
    {%- render 'dce-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      subheading: section.settings.subheading
    -%}

    {%- if dce_rows.size > 0 -%}
      <div class="dce-transformation-v1__labels">
        <span>{{ section.settings.before_label | default: 'Antes' }}</span>
        <span>{{ section.settings.after_label | default: 'Después' }}</span>
      </div>

      <ol class="dce-transformation-v1__timeline">
        {%- for block in dce_rows -%}
          <li
            class="dce-transformation-v1__row"
            data-dce-animate="{% cycle 'fade-left', 'fade-right' %}"
            style="transition-delay: {{ forloop.index0 | times: 100 }}ms"
            {{ block.shopify_attributes }}
          >
            <div class="dce-transformation-v1__before">
              <span class="dce-transformation-v1__mark dce-transformation-v1__mark--no">{%- render 'dce-icon', name: 'close' -%}</span>
              <span>{{ block.settings.before_text }}</span>
            </div>
            <div class="dce-transformation-v1__dot" aria-hidden="true"></div>
            <div class="dce-transformation-v1__after">
              <span class="dce-transformation-v1__mark dce-transformation-v1__mark--yes">{%- render 'dce-icon', name: 'check_mark' -%}</span>
              <span>{{ block.settings.after_text }}</span>
            </div>
          </li>
        {%- endfor -%}
      </ol>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DCE — Transformación v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "El antes y el después"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Etiqueta — antes",
      "default": "Antes"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "Etiqueta — después",
      "default": "Después"
    },
    {
      "type": "checkbox",
      "id": "dark_mode",
      "label": "Fondo oscuro",
      "info": "Genera contraste dramático con las secciones vecinas — recomendado.",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "info": "Sobrescribe el fondo oscuro por defecto si se completa."
    }
  ],
  "blocks": [
    {
      "type": "comparison_item",
      "name": "Fila antes/después",
      "settings": [
        {
          "type": "text",
          "id": "before_text",
          "label": "Texto — antes",
          "default": "Describí el estado actual del lector."
        },
        {
          "type": "text",
          "id": "after_text",
          "label": "Texto — después",
          "default": "Describí el resultado después de usar el producto."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — Transformación v1",
      "blocks": [
        { "type": "comparison_item" },
        { "type": "comparison_item" },
        { "type": "comparison_item" }
      ]
    }
  ]
}
{% endschema %}
