{%- comment -%}
  DCE Transformation — variant 1 (before → after statement lines).
  Funnel role: makes the felt experience of change concrete — not a
  feature comparison, a single line per shift, read almost like a list of
  small relief moments. Deliberately not two boxes / a checklist: this is
  the emotional payoff right after Problema's identification, and should
  read with the same big-statement rhythm, just lighter.
{%- endcomment -%}

{{ 'dce-transformation-v1.css' | asset_url | stylesheet_tag }}
{{ 'dce-section-header.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign dce_rows = section.blocks | where: 'type', 'comparison_item'
-%}

<section
  class="dce-transformation-v1 dce-section{% if section.settings.dark_mode %} dce-section--dark{% endif %}"
  {% if section.settings.background_color != blank %}
    style="background-color: {{ section.settings.background_color }};"
  {% endif %}
>
  <div class="dce-transformation-v1__backdrop" aria-hidden="true"></div>
  <div class="dce-container dce-transformation-v1__container">
    {%- render 'dce-section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      subheading: section.settings.subheading
    -%}

    {%- if dce_rows.size > 0 -%}
      <ul class="dce-transformation-v1__stack" role="list">
        {%- for block in dce_rows -%}
          <li
            class="dce-transformation-v1__line"
            data-dce-animate="fade-up"
            style="transition-delay: {{ forloop.index0 | times: 120 }}ms"
            {{ block.shopify_attributes }}
          >
            <span class="dce-transformation-v1__before">{{ block.settings.before_text }}</span>
            <span class="dce-transformation-v1__arrow" aria-hidden="true">→</span>
            <span class="dce-transformation-v1__after">{{ block.settings.after_text }}</span>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DCE — Transformación v1",
  "tag": "section",
  "class": "dce-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "El antes y el después"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Etiqueta — antes",
      "info": "No se usa en esta variante — se mantiene por compatibilidad."
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "Etiqueta — después",
      "info": "No se usa en esta variante — se mantiene por compatibilidad."
    },
    {
      "type": "checkbox",
      "id": "dark_mode",
      "label": "Fondo oscuro",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "info": "Sobrescribe el fondo oscuro por defecto si se completa."
    }
  ],
  "blocks": [
    {
      "type": "comparison_item",
      "name": "Cambio",
      "settings": [
        {
          "type": "text",
          "id": "before_text",
          "label": "Antes",
          "default": "Describí el estado actual del lector."
        },
        {
          "type": "text",
          "id": "after_text",
          "label": "Después",
          "default": "Describí cómo se siente el cambio."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DCE — Transformación v1",
      "blocks": [
        { "type": "comparison_item" },
        { "type": "comparison_item" },
        { "type": "comparison_item" }
      ]
    }
  ]
}
{% endschema %}
